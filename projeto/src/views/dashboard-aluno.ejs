<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Painel do Aluno - Academix Eventos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-primary mb-4">
    <div class="container d-flex justify-content-between">
        <a class="navbar-brand" href="/dashboard">🎓 Academix Eventos</a>
        <div class="text-white">
            <span class="me-3">Olá, <%= usuario.nome %> (Aluno)</span>
            <a href="/logout" class="btn btn-sm btn-outline-light">Sair</a>
        </div>
    </div>
</nav>

<div class="container">
    <h4 class="mb-4">Minhas Inscrições</h4>
    <div class="card shadow-sm mb-5">
        <div class="card-body">
            <table class="table">
                <thead><tr><th>Evento</th><th>Data</th><th>Status / Ação</th></tr></thead>
                <tbody>
                    <% if (inscricoes && inscricoes.length > 0) { %>
                        <% inscricoes.forEach(insc => { %>
                            <tr>
                                <td><%= insc.titulo %></td>
                                <td><%= new Date(insc.data).toLocaleDateString('pt-BR') %></td>
                                <td>
                                    <form action="/certificados" method="POST" class="d-inline">
                                        <input type="hidden" name="id_inscricao" value="<%= insc.id %>">
                                        <button type="submit" class="btn btn-sm btn-success">Gerar Certificado</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="3" class="text-muted">Você ainda não está inscrito em nenhum evento.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <h4 class="mb-4">Eventos Disponíveis para Inscrição</h4>
    <div class="row">
        <% if (eventos && eventos.length > 0) { %>
            <% eventos.forEach(evento => { %>
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title"><%= evento.titulo %></h5>
                            <p class="card-text text-muted"><%= new Date(evento.data).toLocaleDateString('pt-BR') %> às <%= evento.horario_inicio %></p>
                            
                            <form action="/inscricoes" method="POST">
                                <input type="hidden" name="id_evento" value="<%= evento.id %>">
                                <button type="submit" class="btn btn-primary w-100">Inscrever-se</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

</body>
</html>