<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Sala - Academix Eventos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0">Cadastrar Nova Sala</h5>
                    </div>
                    <div class="card-body p-4">
                        <form action="/salas" method="POST">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Nome da Sala</label>
                                <input type="text" name="nome" class="form-control" required placeholder="Ex: Auditório Principal">
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">Capacidade (Pessoas)</label>
                                <input type="number" name="capacidade" class="form-control" required placeholder="Ex: 250">
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Localização (Bloco/Andar)</label>
                                <input type="text" name="localizacao" class="form-control" required placeholder="Ex: Bloco A - Térreo">
                            </div>
                            
                            <div class="d-flex justify-content-end">
                                <a href="/salas" class="btn btn-outline-secondary me-2">Cancelar</a>
                                <button type="submit" class="btn btn-success">Salvar Sala</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>