<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eventos - Academix Eventos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Gestão de Eventos</h2>
            <div>
                <a href="/dashboard" class="btn btn-secondary me-2">Voltar ao Dashboard</a>
                <a href="/eventos/novo" class="btn btn-primary">+ Novo Evento</a>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Título</th>
                            <th>Data</th>
                            <th>Início</th>
                            <th>Fim</th>
                            <th>Sala</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (eventos && eventos.length > 0) { %>
                            <% eventos.forEach(evento => { %>
                                <tr>
                                    <td><%= evento.id %></td>
                                    <td><strong><%= evento.titulo %></strong></td>
                                    <td><%= new Date(evento.data).toLocaleDateString('pt-PT') %></td>
                                    <td><%= evento.horario_inicio %></td>
                                    <td><%= evento.horario_fim %></td>
                                    <td><span class="badge bg-info text-dark"><%= evento.nome_sala %></span></td>
                                    <td>
                                        <a href="/eventos/<%= evento.id %>/editar" class="btn btn-sm btn-outline-primary">Editar</a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">Nenhum evento registado no sistema.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>