<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Palestrantes - Academix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="d-flex justify-content-between mb-4">
            <h2>Gestão de Palestrantes</h2>
            <div>
                <a href="/dashboard" class="btn btn-secondary">Dashboard</a>
                <a href="/palestrantes/novo" class="btn btn-primary">+ Novo Palestrante</a>
            </div>
        </div>
        <div class="card shadow-sm p-3">
            <table class="table">
                <thead class="table-light"><tr><th>ID</th><th>Nome</th><th>E-mail</th><th>Biografia</th></tr></thead>
                <tbody>
                    <% if (palestrantes && palestrantes.length > 0) { %>
                        <% palestrantes.forEach(p => { %>
                            <tr><td><%= p.id %></td><td><strong><%= p.nome %></strong></td><td><%= p.email %></td><td class="text-truncate" style="max-width: 250px;"><%= p.biografia %></td></tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="4" class="text-center">Nenhum palestrante cadastrado.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>